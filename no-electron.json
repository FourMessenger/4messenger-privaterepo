{
  "name": "4-messenger-desktop",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "4 Messenger Desktop Application",
  "author": "4 Messenger",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist -r git@github.com:FourMessenger/FourMessenger.github.io.git",
    "dev:desktop": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build:desktop": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.messenger4.desktop",
    "productName": "4 Messenger",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.social-networking"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    }
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.4.2",
    "@rollup/rollup-android-arm64": "^4.59.0",
    "clsx": "2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "gh-pages": "^6.3.0",
    "idb": "^8.0.3",
    "lucide-react": "^0.563.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "3.4.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "wait-on": "^9.0.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.17",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "7.2.4",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
